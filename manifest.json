{
  "manifest_version": 3,
  "name": "Gitea PR Review Exporter",
  "version": "1.0.0",
  "description": "Export unresolved Gitea pull request review conversations as JSON.",
  "permissions": ["activeTab", "tabs", "downloads", "clipboardWrite", "storage", "scripting"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Gitea PR Review Exporter",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*/*/pulls/*", "https://*/*/*/pulls/*"],
      "include_globs": ["http://git*/*/*/pulls/*", "https://git*/*/*/pulls/*"],
      "js": [
        "content/content.js",
        "content/scrape-core.js",
        "content/helpers.js",
        "content/content-router.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
